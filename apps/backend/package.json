    "prisma:seed": "ts-node src/prisma/seed.ts"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "ts-node src/prisma/seed.ts"
  },
  "dependencies": {
    "@bayan/shared": "1.0.0",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/common": "^10.3.9",
